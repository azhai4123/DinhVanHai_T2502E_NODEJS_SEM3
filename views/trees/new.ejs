<%- include('../partials/header', { title: 'Thêm cây', active: 'trees-new' }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible mb-4" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/">Danh sách cây</a></li>
    <li class="breadcrumb-item active">Thêm mới</li>
  </ol>
</nav>

<%- include('../partials/tree-form', {
  formTitle: 'Thêm cây mới',
  formAction: '/trees',
  formValues: typeof formValues !== 'undefined' ? formValues : { treename: '', description: '', image: '' },
  submitLabel: 'Thêm cây'
}) %>

<%- include('../partials/footer') %>
