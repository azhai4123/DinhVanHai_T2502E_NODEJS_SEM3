<%- include('../partials/header', { title: 'Sửa cây', active: 'trees-edit' }) %>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-danger alert-dismissible mb-4" role="alert">
    <%= error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
<% } %>

<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb mb-0">
    <li class="breadcrumb-item"><a href="/">Danh sách cây</a></li>
    <li class="breadcrumb-item active">Sửa: <%= typeof tree !== 'undefined' && tree ? tree.treename : '' %></li>
  </ol>
</nav>

<%- include('../partials/tree-form', {
  formTitle: 'Sửa thông tin cây',
  formAction: typeof editAction !== 'undefined' ? editAction : '/',
  formValues: typeof formValues !== 'undefined' ? formValues : { treename: '', description: '', image: '' },
  submitLabel: 'Cập nhật'
}) %>

<%- include('../partials/footer') %>
