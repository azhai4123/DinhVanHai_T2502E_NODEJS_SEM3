<% var treeList = (typeof trees !== 'undefined' && trees) ? trees : []; %>
<% var statusStyles = [
  { cls: 'bg-label-primary', label: 'Active' },
  { cls: 'bg-label-success', label: 'Completed' },
  { cls: 'bg-label-info', label: 'Scheduled' },
  { cls: 'bg-label-warning', label: 'Pending' }
]; %>
<%- include('partials/header', { title: 'Danh sách cây', active: 'trees-list' }) %>

<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4">
  <div>
    <h4 class="fw-bold mb-1">Danh sách cây</h4>
    <p class="text-muted mb-0">MongoDB · <code>TreeCollection</code> · giao diện bảng Materio</p>
  </div>
  <div class="d-flex flex-wrap gap-2">
    <a href="/trees/new" class="btn btn-primary"><i class="ri-add-line me-1"></i> Thêm cây mới</a>
    <form action="/reset" method="post" class="d-inline" onsubmit="return confirm('Xóa hết dữ liệu cây? Hành động này không hoàn tác.');">
      <button type="submit" class="btn btn-outline-danger">Reset</button>
    </form>
  </div>
</div>

<div class="card">
  <h5 class="card-header">Table Basic</h5>
  <% if (!treeList || treeList.length === 0) { %>
    <div class="card-body text-center text-muted py-5">
      <p class="mb-3">Chưa có cây nào.</p>
      <a href="/trees/new" class="btn btn-sm btn-primary">Thêm cây đầu tiên</a>
    </div>
  <% } else { %>
    <div class="table-responsive text-nowrap">
      <table class="table">
        <thead>
          <tr>
            <th>Tên cây</th>
            <th>Mô tả</th>
            <th>Ảnh</th>
            <th>Trạng thái</th>
            <th>Thao tác</th>
          </tr>
        </thead>
        <tbody class="table-border-bottom-0">
          <% treeList.forEach(function (tree, idx) { %>
            <% var st = statusStyles[idx % statusStyles.length]; %>
            <% var desc = (tree.description || '').length > 80 ? (tree.description || '').slice(0, 80) + '…' : (tree.description || ''); %>
            <tr>
              <td>
                <i class="ri-leaf-fill ri-22px text-success me-2"></i>
                <span class="fw-medium"><%= tree.treename %></span>
              </td>
              <td class="text-muted" style="max-width: 280px; white-space: normal;"><%= desc %></td>
              <td>
                <% if (tree.image) { %>
                  <img src="<%= tree.image %>" alt="" class="rounded-circle" width="40" height="40" style="object-fit: cover" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('d-none');" />
                  <span class="avatar avatar-sm d-none"><span class="avatar-initial rounded-circle bg-label-secondary"><i class="ri-image-line"></i></span></span>
                <% } else { %>
                  <span class="avatar avatar-sm"><span class="avatar-initial rounded-circle bg-label-secondary"><i class="ri-plant-line"></i></span></span>
                <% } %>
              </td>
              <td><span class="badge rounded-pill <%= st.cls %> me-1"><%= st.label %></span></td>
              <td>
                <div class="d-flex align-items-center gap-1">
                  <a
                    href="/trees/<%= tree._id %>/edit"
                    class="btn btn-sm btn-icon btn-text-secondary rounded-pill"
                    title="Sửa"
                    aria-label="Sửa">
                    <i class="ri-pencil-line ri-20px"></i>
                  </a>
                  <form action="/trees/<%= tree._id %>/delete" method="post" class="d-inline mb-0" onsubmit="return confirm('Xóa cây này khỏi database?');">
                    <button
                      type="submit"
                      class="btn btn-sm btn-icon btn-text-danger rounded-pill"
                      title="Xóa"
                      aria-label="Xóa">
                      <i class="ri-delete-bin-6-line ri-20px"></i>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('partials/footer') %>
